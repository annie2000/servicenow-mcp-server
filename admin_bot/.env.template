# ServiceNow Admin Bot — Credentials Template
# ============================================================
# HOW TO USE:
#   1. Copy this file and rename it to:  .env
#   2. Fill in your ServiceNow instance URL, username, and password
#   3. Save the file — healthcheck.py will read it automatically
#
# SECURITY:
#   - Never commit the .env file to version control (Git)
#   - The .env file stays on your local machine only
#   - Credentials are never sent anywhere except your ServiceNow instance
# ============================================================

# Your ServiceNow instance URL — include https://
SERVICENOW_INSTANCE=https://yourinstance.service-now.com

# Admin username (admin role required; sn_aia_admin for AI Agent tables)
SERVICENOW_USERNAME=admin

# Admin password
SERVICENOW_PASSWORD=your_password_here
